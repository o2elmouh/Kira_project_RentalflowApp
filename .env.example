# ──────────────────────────────────────────────────────────
# FRONTEND — Vite (set in Vercel dashboard → Settings → Environment Variables)
# ──────────────────────────────────────────────────────────

# Supabase project URL (safe to expose — it's in the anon key anyway)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon (public) key — safe to expose
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Set to "true" to enable Supabase auth, "false" to use localStorage only
VITE_USE_AUTH=true

# URL of the Railway backend API (no trailing slash)
VITE_API_URL=https://rentaflow-api.railway.app


# ──────────────────────────────────────────────────────────
# BACKEND — Node.js (set in Railway dashboard → Variables)
# ──────────────────────────────────────────────────────────

# Same Supabase URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key (used only to verify JWTs)
SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — NEVER put this in the frontend or commit it
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Frontend origin for CORS (your Vercel domain)
FRONTEND_URL=https://rentaflow.vercel.app

# Port — Railway sets this automatically, keep 3001 for local dev
PORT=3001

# Node environment
NODE_ENV=production


# ──────────────────────────────────────────────────────────
# OPTIONAL — Email (Railway)
# ──────────────────────────────────────────────────────────

# Resend API key (https://resend.com) — for sending contract PDFs by email
# RESEND_API_KEY=re_xxxxxxxxxxxx
